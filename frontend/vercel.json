{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "functions": {
    "api/poseidon.js": {
      "includeFiles": "public/fishbase_master.json"
    }
  },
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/hobbyist", "destination": "/hobbyist.html" },
    { "source": "/breeder", "destination": "/breeder.html" },
    { "source": "/database", "destination": "/database.html" },
    { "source": "/reef", "destination": "/reef.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/legal", "destination": "/legal.html" }
  ]
}
