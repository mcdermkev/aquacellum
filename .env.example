# =============================================================================
# Aquadex Protocol — Environment Configuration
# TESTNET DEPLOYMENT: Base Sepolia (Chain ID: 84532)
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# --- Deployer Wallet ---
# Export from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=your_private_key_here

# --- RPC Endpoint ---
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# --- Block Explorer Verification ---
# Get a free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# --- Frontend (Vite) ---
# These are exposed to the browser bundle (VITE_ prefix)
VITE_MANAGER_ADDRESS=0x351ca8f34D94F29F6f865Afa419A636324473DeF
VITE_MARKETPLACE_ADDRESS=0x16168B514144e0380610b78d904a4de51ba03Ca3
VITE_CHAIN_ID=84532
VITE_RPC_URL=https://sepolia.base.org
VITE_BLOCK_EXPLORER=https://sepolia.basescan.org
VITE_PRIVY_APP_ID=your_privy_app_id_here

# --- Social Layer (The Reef) ---
# Supabase project: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Poseidon AI Gateway (Vertex AI) ---
# Billed to the Google Cloud project below, so usage draws from project credits.
# Used server-side only (Vercel functions) — NOT exposed to the browser.
GCP_PROJECT_ID=aquacellum
GCP_LOCATION=us-central1
#
# Auth — choose ONE:
#  - Vercel: paste the FULL service-account JSON as a single line:
#      GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#  - Local: point to the key file instead (NEVER commit the file):
#      GOOGLE_APPLICATION_CREDENTIALS=C:\Users\you\.gcp\aquacellum-xxxx.json
GCP_SERVICE_ACCOUNT_JSON=
